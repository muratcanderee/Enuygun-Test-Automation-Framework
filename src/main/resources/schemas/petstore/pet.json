{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "id",
    "name"
  ],
  "properties": {
    "id": {
      "type": [
        "integer",
        "number"
      ]
    },
    "category": {
      "type": "object",
      "properties": {
        "id": {
          "type": [
            "integer",
            "number"
          ]
        },
        "name": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "name": {
      "type": "string"
    },
    "photoUrls": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": [
              "integer",
              "number"
            ]
          },
          "name": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "status": {
      "type": "string"
    }
  },
  "additionalProperties": true
}

